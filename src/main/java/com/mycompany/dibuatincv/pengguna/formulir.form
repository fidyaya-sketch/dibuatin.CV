                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="jLabel9">
                  <Properties>
                    <Property name="text" type="java.lang.String" value="!!Awali bagian yang ingin di point dengan FULL KAPITAL!! &#x25cf;Jenis Pengalaman."/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="jLabel10">
                  <Properties>
                    <Property name="text" type="java.lang.String" value="-Nama tempat. -Lokasi | Bulan, Tahun Mulai &#x2013; Bulan, Tahun Selesai. -Poin tanggung jawab/pencapaian utama."/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="jLabel11">
                  <Properties>
                    <Property name="text" type="java.lang.String" value="Isi dengan projek yang sudah pernah kamu buat baik itu individu maupun tim."/>
