                <Component class="javax.swing.JLabel" name="jLabel2">
                  <Properties>
                    <Property name="text" type="java.lang.String" value="Tuliskan pendidikan terakhir saja, cukup enter saja format yang diberi nomor"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="jLabel4">
                  <Properties>
                    <Property name="text" type="java.lang.String" value="1. Nama Universitas. 2. Nama Fakultas/jurusan. 3. Gelar akademik. 4. IPK/Nilai Rapot. 5. Bulan &amp; tahun kelulusan"/>
                  </Properties>
                </Component>
                <Component class="javax.swing.JLabel" name="jLabel5">
