                  <Properties>
                    <Property name="text" type="java.lang.String" value="&quot;Mengenal CV ATS Friendly: Format dokumen yang dirancang khusus agar mudah dibaca oleh Applicant Tracking System, yaitu sistem perangkat lunak otomatis perusahaan"/>
